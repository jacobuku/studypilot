# ============================================================
# StudyPilot — Environment Variables
# Copy this file to .env.local and fill in your values
# ============================================================

# API Base URL (leave empty to use Next.js API routes)
NEXT_PUBLIC_API_URL=

# LLM Provider — pick one:
ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...

# Canvas LMS (optional — can also be set per-user in Settings)
# CANVAS_DEFAULT_DOMAIN=university.instructure.com

# File Storage (pick one)
# AWS_S3_BUCKET=studypilot-uploads
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# SUPABASE_URL=https://xxx.supabase.co
# SUPABASE_ANON_KEY=

# Database (pick one)
# DATABASE_URL=postgresql://user:pass@host:5432/studypilot
# MONGODB_URI=mongodb+srv://...

# Auth (pick one)
# NEXTAUTH_SECRET=your-secret-here
# CLERK_PUBLISHABLE_KEY=pk_...
# CLERK_SECRET_KEY=sk_...
